# MongoDB Connection String (Replace with your Atlas connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zenrestro

# Server Port
PORT=5000

# JWT Secret (Use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key

# Allowed Origins (comma-separated URLs for CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.onrender.com
